{
    "manifest_version": 3,
    "name": "Ofertas Scraper",
    "version": "1.0",
    "description": "Scrapea ofertas de productos y las guarda en IndexedDB.",
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png"
        }
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "https://*/*"
    ]
}